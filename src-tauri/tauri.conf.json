{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "win-launcher",
  "version": "0.1.1",
  "identifier": "com.win-launcher.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "WinLauncher",
        "width": 640,
        "height": 420,
        "minWidth": 640,
        "minHeight": 420,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": false,
        "backgroundColor": [0, 0, 0, 0]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
